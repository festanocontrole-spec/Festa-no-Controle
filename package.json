{
  "name": "festa-no-controle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "fix:encoding": "powershell -ExecutionPolicy Bypass -File scripts/dev/fix-encoding.ps1",
    "check:encoding": "powershell -ExecutionPolicy Bypass -File scripts/dev/check-encoding.ps1",
    "verify": "npm run fix:encoding && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.23",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "description": "Plataforma para vender, planejar, operar e prestar contas de festas comunitárias e beneficentes."
}
